# ─── Sanity (Next.js website) ────────────────────────────────────────────────
# Used by Next.js for server-side data fetching. Find these at:
# https://sanity.io/manage → your project → API

NEXT_PUBLIC_SANITY_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01

# ─── Sanity (Standalone Studio) ──────────────────────────────────────────────
# Used by the Sanity Studio when running `npm run studio`.
# Must match the values above exactly.

SANITY_STUDIO_PROJECT_ID=your_project_id_here
SANITY_STUDIO_DATASET=production

# ─── Sanity Write Token ───────────────────────────────────────────────────────
# Used server-side only for the contact form API route.
# Create one at sanity.io/manage → API → Tokens → Add API Token (Editor role)

SANITY_API_TOKEN=your_write_token_here

# ─── Email (Resend) ───────────────────────────────────────────────────────────
# Sign up at resend.com, create an API key

RESEND_API_KEY=your_resend_api_key_here
CONTACT_EMAIL_TO=your@email.com

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Sign up at stripe.com → Developers → API keys
# Use test keys (pk_test_ / sk_test_) during development.
# Switch to live keys (pk_live_ / sk_live_) before going live.

NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here

# Webhook signing secret — generated when you create a webhook endpoint.
# For local testing: run `stripe listen --forward-to localhost:3000/api/webhooks/stripe`
# and use the whsec_ secret it prints. Register the live endpoint in the Stripe
# Dashboard (Developers → Webhooks) before going live.
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── Site URL ─────────────────────────────────────────────────────────────────
# Used to build absolute success/cancel redirect URLs for Stripe Checkout.
# No trailing slash. Use http://localhost:3000 locally.

NEXT_PUBLIC_SITE_URL=https://wallensdesign.se
